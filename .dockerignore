# Dependencies
# Ignore all node_modules folders (Docker will install dependencies inside the container)
node_modules
**/node_modules

# Build artifacts
# Ignore compiled output and framework-specific build directories
dist
build
.next
out

# Logs and temporary files
# Prevent debug and log files from being copied into the image
*.log
npm-debug.log*
yarn-debug.log*

# Git and ignore files
# These are only relevant locally, not inside the container
.git
.gitignore
.dockerignore

# System files
# Common OS-specific files should not be included
.DS_Store
Thumbs.db

# Docker configuration files
# Dockerfile and docker-compose.yml are used only for building/running, not inside the image
Dockerfile
docker-compose.yml
